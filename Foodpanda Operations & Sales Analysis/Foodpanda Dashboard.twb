      <aliases enabled='yes' />
      <column caption='AOV' datatype='real' name='[Calculation_1327436026767032320]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([price]) / COUNT([order_id])' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_1327436026767081473]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [churned] = &quot;Yes&quot; THEN [order_id] END) / COUNT([order_id])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_1327436026773159939]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([order_id])' />
      </column>
      <column caption='Delivery Success Rate' datatype='real' name='[Calculation_1327436026773889029]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [delivery_status] = &quot;Delivered&quot; THEN [order_id] END) / COUNT([order_id])' />
      </column>
